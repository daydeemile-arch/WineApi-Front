<Window x:Class="SolutionClients.Views.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu -->
        <Border Background="#8B0000"
                Grid.Column="0">

            <StackPanel Margin="15">

                <TextBlock Text="Wine App"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,40"/>

                <Button Content="🍷 Wines"
                        Height="45"
                        Margin="0,10"
                        FontSize="16"/>

                <Button Content="👤 Customers"
                        Height="45"
                        Margin="0,10"
                        FontSize="16"/>

                <Button Content="🚚 Suppliers"
                        Height="45"
                        Margin="0,10"
                        FontSize="16"/>

                <Button Content="💰 Sales"
                        Height="45"
                        Margin="0,10"
                        FontSize="16"/>

                <Button Content="📦 Stock"
                        Height="45"
                        Margin="0,10"
                        FontSize="16"/>

                <Button Content="Logout"
                        Height="45"
                        Margin="0,50,0,0"
                        FontSize="16"
                        Background="Black"
                        Foreground="White"/>

            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1"
              Background="#F5F5F5">

            <TextBlock Text="Welcome to Wine Management"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

        </Grid>

    </Grid>
</Window>
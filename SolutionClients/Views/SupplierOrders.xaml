<Page x:Class="SolutionClients.Views.SupplierOrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StockView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📦 Commandes Fournisseurs"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Filtre statut -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Filtrer :" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="cbFiltreStatut" Width="160" Height="35"
                      SelectionChanged="cbFiltreStatut_SelectionChanged">
                <ComboBoxItem Content="Tous" IsSelected="True"/>
                <ComboBoxItem Content="EnAttente"/>
                <ComboBoxItem Content="Acceptée"/>
            </ComboBox>
            <Button Content="🔄 Rafraîchir"
                    Width="120" Height="35" Margin="15,0,0,0"
                    Background="#333333" Foreground="White"
                    BorderBrush="Transparent" Cursor="Hand"
                    Click="BtnRefresh_Click"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15">
            <DataGrid x:Name="dgCommandes"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      ColumnHeaderHeight="40"
                      RowHeight="36">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatutCommande}" Value="EnAttente">
                                <Setter Property="Background" Value="#FFF8E1"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatutCommande}" Value="Acceptée">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"           Binding="{Binding IdCommande}"     Width="50"/>
                    <DataGridTextColumn Header="Vin"          Binding="{Binding NomVin}"         Width="*"/>
                    <DataGridTextColumn Header="Fournisseur"  Binding="{Binding NomFournisseur}" Width="*"/>
                    <DataGridTextColumn Header="Quantité"     Binding="{Binding Quantite}"       Width="80"/>
                    <DataGridTextColumn Header="Statut"       Binding="{Binding StatutCommande}" Width="100"/>
                    <DataGridTextColumn Header="Date"         Binding="{Binding DateCommande, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="130"/>
                    <DataGridTextColumn Header="Acceptation"  Binding="{Binding DateAcceptation, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="130"/>
                    <DataGridTemplateColumn Header="Action" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✅ Accepter"
                                        Height="28"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        BorderBrush="Transparent"
                                        Cursor="Hand"
                                        Visibility="{Binding StatutCommande, Converter={StaticResource StatutToVisibilityConverter}}"
                                        Click="BtnAccepter_Click"
                                        Tag="{Binding IdCommande}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
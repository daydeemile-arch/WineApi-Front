<Window x:Class="SolutionClients.DashboardClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Dashboard"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#8B0000">

            <StackPanel Margin="15">

                <TextBlock Text="🍷 Wine Shop"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,40"/>

                <Button Content="🍷 Browse Wines"
                        Height="50"
                        Margin="0,10"
                        Click="BtnWines_Click"/>

                <Button Content="🛒 My Orders"
                        Height="50"
                        Margin="0,10"
                        Click="BtnOrders_Click"/>

                <Button Content="👤 My Profile"
                        Height="50"
                        Margin="0,10"
                        Click="BtnProfile_Click"/>

                <Button Content="Logout"
                        Height="45"
                        Margin="0,50,0,0"
                        Background="Black"
                        Foreground="White"
                        Click="BtnLogout_Click"/>

            </StackPanel>

        </Border>

        <!-- Main content -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
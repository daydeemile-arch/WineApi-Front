<Page x:Class="SolutionClients.Views.CustomersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CustomersView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Text="👤 Customer Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Barre de recherche -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <TextBox x:Name="txtSearchCustomer"
                     Width="300"
                     Height="35"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearchCustomer_TextChanged"/>

            <Button Content="🔍 Search"
                    Width="110"
                    Height="35"
                    Margin="10,0,0,0"
                    Background="#333333"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Cursor="Hand"
                    Click="BtnSearch_Click"/>
        </StackPanel>

        <!-- Contenu principal -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgCustomers"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="dgCustomers_SelectionChanged"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeight="32"
                          FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"           Binding="{Binding Id}"           Width="50"/>
                        <DataGridTextColumn Header="Prénom"       Binding="{Binding FirstName}"    Width="*"/>
                        <DataGridTextColumn Header="Nom"          Binding="{Binding LastName}"     Width="*"/>
                        <DataGridTextColumn Header="Email"        Binding="{Binding Email}"        Width="*"/>
                        <DataGridTextColumn Header="Adresse"       Binding="{Binding Adresse}" Width="70"/>
                        
                    </DataGrid.Columns>
                </DataGrid>

            </Border>

            <!-- Formulaire -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Prenom" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtFirstName"
                                 Height="32"
                                 Margin="0,0,0,12"
                                 Padding="6,4"/>

                        <TextBlock Text="Nom" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtLastName"
                                 Height="32"
                                 Margin="0,0,0,12"
                                 Padding="6,4"/>

                        <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtEmail"
                                 Height="32"
                                 Margin="0,0,0,12"
                                 Padding="6,4"/>

                        <Separator Margin="0,4,0,12"/>


                        <TextBlock Text="Adresse" FontWeight="SemiBold" Margin="0,0,0,3"/>
                        <TextBox x:Name="txtAdresse"
                                 Height="32"
                                 Margin="0,0,0,12"
                                 Padding="6,4"/>

                        

                        <!-- Statut -->
                        <TextBlock x:Name="TxtStatut"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   FontSize="12"/>

                        <Button Content="➕ Add Customer"
                                Height="38"
                                Margin="0,4"
                                Background="#8B0000"
                                Foreground="White"
                                BorderBrush="Transparent"
                                Cursor="Hand"
                                Click="BtnAdd_Click"/>

                        <Button Content="✏️ Update Customer"
                                Height="38"
                                Margin="0,4"
                                Background="#1565C0"
                                Foreground="White"
                                BorderBrush="Transparent"
                                Cursor="Hand"
                                Click="BtnUpdate_Click"/>

                        <Button Content="🗑️ Delete Customer"
                                Height="38"
                                Margin="0,4"
                                Background="#D32F2F"
                                Foreground="White"
                                BorderBrush="Transparent"
                                Cursor="Hand"
                                Click="BtnDelete_Click"/>

                        <Button Content="🔄 Clear"
                                Height="38"
                                Margin="0,4"
                                Background="#757575"
                                Foreground="White"
                                BorderBrush="Transparent"
                                Cursor="Hand"
                                Click="BtnClear_Click"/>

                    </StackPanel>
                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>
</Page>

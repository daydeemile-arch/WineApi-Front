<Page x:Class="SolutionClients.Views.StockView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StockView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="📦 Stock Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Content -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <DataGrid x:Name="dgStock"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"/>

        </Border>

    </Grid>
</Page>
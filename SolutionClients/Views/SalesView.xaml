<Page x:Class="SolutionClients.Views.SalesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SalesView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="💰 Sales Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Search -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <TextBox x:Name="txtSearchSale"
                     Width="300"
                     Height="35"
                     VerticalContentAlignment="Center"/>

            <Button Content="Search"
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Main -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgSales"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"/>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Customer"/>
                    <ComboBox x:Name="cbCustomer"
                              Height="35"
                              Margin="0,5,0,15"/>

                    <TextBlock Text="Wine"/>
                    <ComboBox x:Name="cbWine"
                              Height="35"
                              Margin="0,5,0,15"/>

                    <TextBlock Text="Quantity"/>
                    <TextBox x:Name="txtQuantity"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Total Amount"/>
                    <TextBox x:Name="txtTotal"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Sale Date"/>
                    <DatePicker x:Name="dpSaleDate"
                                Margin="0,5,0,25"/>

                    <Button Content="Add Sale"
                            Height="40"
                            Margin="0,5"
                            Background="#8B0000"
                            Foreground="White"/>

                    <Button Content="Update Sale"
                            Height="40"
                            Margin="0,5"/>

                    <Button Content="Delete Sale"
                            Height="40"
                            Margin="0,5"
                            Background="#D32F2F"
                            Foreground="White"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>
<Page x:Class="SolutionClients.Views.SalesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SalesView"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Text="💰 Sales Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Recherche -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">
            <TextBox x:Name="txtSearchSale"
                     Width="300"
                     Height="35"
                     VerticalContentAlignment="Center"/>
            <Button x:Name="btnSearch"
                    Content="Search"
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="BtnSearch_Click"/>
        </StackPanel>

        <!-- Contenu principal -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid avec sous-grille -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgSales"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="dgSales_SelectionChanged"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          ColumnHeaderHeight="40"
                          RowHeight="36"
                          RowDetailsVisibilityMode="VisibleWhenSelected">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                           Binding="{Binding Id}"
                                           Width="50"/>
                        <DataGridTextColumn Header="Client"
                                           Binding="{Binding CustomerName}"
                                           Width="*"/>
                        <DataGridTextColumn Header="Total €"
                                           Binding="{Binding TotalAmount, StringFormat={}{0:F2}}"
                                           Width="90"/>
                        <DataGridTextColumn Header="Date"
                                           Binding="{Binding DateSale, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                           Width="130"/>
                    </DataGrid.Columns>

                    <!-- Sous-grille des lignes de vente -->
                    <!-- Sous-grille des lignes de vente -->
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#FFF8F0"
                Padding="20,10"
                BorderThickness="0,1,0,1"
                BorderBrush="#E0C8A0"
                Margin="50,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="🍷 Détail des vins achetés"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           FontSize="13"/>
                                    <DataGrid ItemsSource="{Binding Lines}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="#D0B080"
                          RowHeight="30"
                          ColumnHeaderHeight="32"
                          HorizontalAlignment="Stretch"
                          Width="Auto" >
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Vin"
                       Binding="{Binding WineName}"
                       Width="*"/>
                                            <DataGridTextColumn Header="Quantité"
                       Binding="{Binding Quantity}"
                       Width="150"/>
                                            <DataGridTextColumn Header="Prix unit. €"
                       Binding="{Binding UnitPrice, StringFormat={}{0:F2}}"
                       Width="200"/>
                                            <DataGridTextColumn Header="Sous-total €"
                       Binding="{Binding SubTotal, StringFormat={}{0:F2}}"
                       Width="200"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>

                </DataGrid>
            </Border>

            <!-- Formulaire -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Customer" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbCustomer"
                                  Height="35"
                                  Margin="0,0,0,15"/>

                        <TextBlock Text="Wine" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbWine"
                                  Height="35"
                                  Margin="0,0,0,15"/>

                        <TextBlock Text="Quantity" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtQuantity"
                                 Height="35"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Total Amount" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtTotal"
                                 Height="35"
                                 Margin="0,0,0,15"
                                 IsReadOnly="True"/>

                        <TextBlock Text="Sale Date" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpSaleDate"
                                    Margin="0,0,0,25"/>

                        <Button Content="Add Sale"
                                Height="40"
                                Margin="0,5"
                                Background="#8B0000"
                                Foreground="White"
                                Click="BtnAddSale_Click"/>

                        <Button Content="Update Sale"
                                Height="40"
                                Margin="0,5"
                                Click="BtnUpdateSale_Click"/>

                        <Button Content="Delete Sale"
                                Height="40"
                                Margin="0,5"
                                Background="#D32F2F"
                                Foreground="White"
                                Click="BtnDeleteSale_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</Page>
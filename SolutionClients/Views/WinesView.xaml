<Page x:Class="SolutionClients.Views.WinesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WinesView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Text="🍷 Wine Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Bandeau alerte stock bas -->
        <Border x:Name="BandeauAlerte"
                Grid.Row="1"
                Background="#C62828"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtAlerte"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Recherche -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">
            <TextBox x:Name="txtSearch"
                     Width="300"
                     Height="35"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearch_TextChanged"/>
            <Button Content="Search"
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="BtnSearch_Click"/>
        </StackPanel>

        <!-- Contenu principal -->
        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgWines"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="dgWines_SelectionChanged"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          ColumnHeaderHeight="40">

                    <!-- Style ligne rouge si stock bas -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBelowThreshold}" Value="True">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"           Binding="{Binding Id}"           Width="50"/>
                        <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="*"/>
                        <DataGridTextColumn Header="Type"         Binding="{Binding Type}"         Width="*"/>
                        <DataGridTextColumn Header="Price (€)"    Binding="{Binding Price, StringFormat={}{0:F2}}" Width="90"/>
                        <DataGridTextColumn Header="Stock"        Binding="{Binding QuantityStock}" Width="70"/>
                        <DataGridTextColumn Header="Threshold"    Binding="{Binding Threshold}"    Width="80"/>
                        <DataGridTextColumn Header="Qté Commande" Binding="{Binding QuantiteCommande}" Width="100"/>
                        <DataGridTextColumn Header="Provider ID"  Binding="{Binding ProviderId}"   Width="90"/>
                    </DataGrid.Columns>

                </DataGrid>
            </Border>

            <!-- Formulaire -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Wine Name" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtWineName" Height="35" Margin="0,0,0,12"/>

                    <TextBlock Text="Price (€)" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtPrice" Height="35" Margin="0,0,0,12"/>

                    <TextBlock Text="Stock Quantity" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtStock" Height="35" Margin="0,0,0,12"/>

                    <TextBlock Text="Low Stock Threshold" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtThreshold" Height="35" Margin="0,0,0,12"/>

                    <TextBlock Text="Qté à commander" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox x:Name="txtQuantiteCommande" Height="35" Margin="0,0,0,12"/>

                    <TextBlock Text="Wine Type" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cbWineType" Height="35" Margin="0,0,0,20">
                        <ComboBoxItem Content="Rouge"/>
                        <ComboBoxItem Content="Blanc"/>
                        <ComboBoxItem Content="Rosé"/>
                        <ComboBoxItem Content="Pétillant"/>
                    </ComboBox>

                    <TextBlock x:Name="TxtStatut" TextWrapping="Wrap" Margin="0,0,0,10" FontSize="12"/>

                    <Button Content="➕ Add Wine"    Height="40" Margin="0,5" Background="#8B0000"
                            Foreground="White" BorderBrush="Transparent" Cursor="Hand" Click="BtnAdd_Click"/>
                    <Button Content="✏️ Update Wine" Height="40" Margin="0,5" Background="#1565C0"
                            Foreground="White" BorderBrush="Transparent" Cursor="Hand" Click="BtnUpdate_Click"/>
                    <Button Content="🗑️ Delete Wine" Height="40" Margin="0,5" Background="#D32F2F"
                            Foreground="White" BorderBrush="Transparent" Cursor="Hand" Click="BtnDelete_Click"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
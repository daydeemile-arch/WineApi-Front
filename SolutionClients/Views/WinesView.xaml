<Page x:Class="SolutionClients.Views.WinesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WinesView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🍷 Wine Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Search -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <TextBox x:Name="txtSearch"
                     Width="300"
                     Height="35"
                     FontSize="14"
                     VerticalContentAlignment="Center"/>

            <Button Content="Search"
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgWines"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          SelectionChanged="dgWines_SelectionChanged"/>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Wine Name"/>
                    <TextBox x:Name="txtWineName"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Price"/>
                    <TextBox x:Name="txtPrice"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Stock Quantity"/>
                    <TextBox x:Name="txtStock"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Low Stock Threshold"/>
                    <TextBox x:Name="txtThreshold"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Wine Type"/>
                    <ComboBox x:Name="cbWineType"
                              Height="35"
                              Margin="0,5,0,25"/>

                    <Button Content="Add Wine"
                            Height="40"
                            Margin="0,5"
                            Background="#8B0000"
                            Foreground="White"/>

                    <Button Content="Update Wine"
                            Height="40"
                            Margin="0,5"/>

                    <Button Content="Delete Wine"
                            Height="40"
                            Margin="0,5"
                            Background="#D32F2F"
                            Foreground="White"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>
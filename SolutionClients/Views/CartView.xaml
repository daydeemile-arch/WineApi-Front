<Page x:Class="SolutionClients.Views.CartView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CartView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🛒 My Cart"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <DataGrid x:Name="dgCart"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Wine"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridTextColumn Header="Price (€)"
                                    Binding="{Binding Price}"
                                    Width="120"/>

            </DataGrid.Columns>

        </DataGrid>

        <Button Grid.Row="2"
                Content="✅ Checkout"
                Height="45"
                Width="180"
                HorizontalAlignment="Right"
                Margin="0,20,0,0"
                Background="#8B0000"
                Foreground="White"
                Click="BtnCheckout_Click"/>

    </Grid>
</Page>
<Page x:Class="SolutionClients.Views.SuppliersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SuppliersView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🚚 Supplier Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Search -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <TextBox x:Name="txtSearchSupplier"
                     Width="300"
                     Height="35"
                     FontSize="14"
                     VerticalContentAlignment="Center"/>

            <Button x:Name="btnSearch"
                    Content="Search"
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="BtnSearch_Click"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgSuppliers"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="dgSuppliers_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        <DataGridTextColumn Header="Full Address" Binding="{Binding FullAddress}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Supplier Name" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSupplierName"
                                 Height="35"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Phone" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPhone"
                                 Height="35"
                                 Margin="0,0,0,15"/>

                        <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtEmail"
                                 Height="35"
                                 Margin="0,0,0,15"/>

                        <!-- Address Section -->
                        <TextBlock Text="Address Information" FontWeight="Bold" FontSize="14" Margin="0,10,0,10" Foreground="#8B0000"/>

                        <TextBlock Text="Street Number" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNumRue"
                                 Height="35"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Street Name" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNomRue"
                                 Height="35"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Postal Code" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCodePostal"
                                 Height="35"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="City" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtVille"
                                 Height="35"
                                 Margin="0,0,0,25"/>

                        <Button x:Name="btnAddSupplier"
                                Content="Add Supplier"
                                Height="40"
                                Margin="0,5"
                                Background="#8B0000"
                                Foreground="White"
                                Click="BtnAddSupplier_Click"/>

                        <Button x:Name="btnUpdateSupplier"
                                Content="Update Supplier"
                                Height="40"
                                Margin="0,5"
                                Click="BtnUpdateSupplier_Click"/>

                        <Button x:Name="btnDeleteSupplier"
                                Content="Delete Supplier"
                                Height="40"
                                Margin="0,5"
                                Background="#D32F2F"
                                Foreground="White"
                                Click="BtnDeleteSupplier_Click"/>

                    </StackPanel>
                </ScrollViewer>

            </Border>

        </Grid>

    </Grid>
</Page>
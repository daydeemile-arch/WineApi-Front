<Page x:Class="SolutionClients.Views.SuppliersView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SuppliersView"
      Background="#F5F5F5">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🚚 Supplier Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Search -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">

            <TextBox x:Name="txtSearchSupplier"
                     Width="300"
                     Height="35"
                     FontSize="14"
                     VerticalContentAlignment="Center"/>

            <Button Content="Search"
                    Width="100"
                    Height="35"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,0,15,0">

                <DataGrid x:Name="dgSuppliers"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"/>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Supplier Name"/>
                    <TextBox x:Name="txtSupplierName"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Phone"/>
                    <TextBox x:Name="txtPhone"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Email"/>
                    <TextBox x:Name="txtEmail"
                             Height="35"
                             Margin="0,5,0,15"/>

                    <TextBlock Text="Address"/>
                    <TextBox x:Name="txtAddress"
                             Height="35"
                             Margin="0,5,0,25"/>

                    <Button Content="Add Supplier"
                            Height="40"
                            Margin="0,5"
                            Background="#8B0000"
                            Foreground="White"/>

                    <Button Content="Update Supplier"
                            Height="40"
                            Margin="0,5"/>

                    <Button Content="Delete Supplier"
                            Height="40"
                            Margin="0,5"
                            Background="#D32F2F"
                            Foreground="White"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Page>
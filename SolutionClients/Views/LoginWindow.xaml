<Window x:Class="SolutionClients.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="498"
        Width="815"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Border Width="349"
                Height="420"
                Background="White"
                CornerRadius="10"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Wine Management"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Email"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="TxtEmail"
                         Height="35"
                         Margin="0,0,0,15"
                         FontSize="14"/>

                <TextBlock Text="Password"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="TxtPassword"
                             Height="35"
                             Margin="0,0,0,25"
                             FontSize="14"/>

                <Button Content="Login"
                        Height="40"
                        FontSize="16"
                        Background="#8B0000"
                        Foreground="White"
                        BorderBrush="Transparent"
                        Cursor="Hand"
                        Click="BtnLogin_Click"/>

                <TextBlock x:Name="TxtToken"
                           Margin="0,15,0,0"
                           TextWrapping="Wrap"
                           Foreground="Green"
                           FontSize="11"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>
    </Grid>
</Window>
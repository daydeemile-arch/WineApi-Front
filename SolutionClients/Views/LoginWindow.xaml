<Window x:Class="SolutionClients.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="498"
        Width="815"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Border Width="349"
                Height="420"
                Background="White"
                CornerRadius="10"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Wine Management"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Email"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="TxtEmail"
                         Height="35"
                         Margin="0,0,0,15"
                         FontSize="14"/>

                <TextBlock Text="Password"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="TxtPassword"
                             Height="35"
                             Margin="0,0,0,25"
                             FontSize="14"/>
                <TextBlock x:Name="TxtToken"
                           TextWrapping="Wrap"
                           Foreground="Green"
                           FontSize="11"
                           Margin="0,0,0,15"
                           />

                <Button Content="Login"
                        Height="40"
                        FontSize="16"
                        Background="#8B0000"
                        Foreground="White"
                        BorderBrush="Transparent"
                        Cursor="Hand"
                        Click="BtnLogin_Click"
                        Margin="0,0,0,15">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#8B0000"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="22">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#5E0000"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3B0000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Register"
                    Height="40"
                    FontSize="16"
                    Background="#8B0000"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Cursor="Hand"
                    Click="BtnRegister_Click"
                    Margin="0,0,0,5">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="#8B0000"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="22">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#5E0000"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3B0000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Border>
    </Grid>
</Window>